*.py[cod]
*$py.class

# Distribution / packaging
.Python
env/
build/
dist/
.eggs/
*.egg-info/

# OS files
.DS_Store
Thumbs.db

# Visual Studio Code
.vscode/

# Jupyter Notebook checkpoints
.ipynb_checkpoints

