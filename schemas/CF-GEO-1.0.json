{\n  \"title\": \"CF-GEO-1.0 Schema\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"run_level_metadata\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"seed\": {\n          \"type\": \"integer\",\n          \"description\": \"Random seed used in the run\"\n        },\n        \"width\": {\n          \"type\": \"integer\",\n          \"description\": \"Width of the model\"\n        },\n        \"depth\": {\n          \"type\": \"integer\",\n          \"description\": \"Depth of the model\"\n        },\n        \"theta\": {\n          \"type\": \"number\",\n          \"minimum\": 0,\n          \"maximum\": 90,\n          \"description\": \"Angle theta within [0, 90]\"\n        },\n        \"optimizer\": {\n          \"type\": \"string\",\n          \"description\": \"Optimizer algorithm used\"\n        },\n        \"learning_rate\": {\n          \"type\": \"number\",\n          \"description\": \"Learning rate for the optimization\"\n        },\n        \"weight_decay\": {\n          \"type\": \"number\",\n          \"description\": \"Weight decay factor\"\n        },\n        \"timestamps\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\",\n            \"format\": \"date-time\"\n          },\n          \"description\": \"Timestamps for the run events\"\n        }\n      },\n      \"required\": [\n        \"seed\", \"width\", \"depth\", \"theta\", \"optimizer\", \"learning_rate\", \"weight_decay\", \"timestamps\"\n      ]\n    },\n    \"time_series_metrics\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"train_loss\": {\n          \"type\": \"number\",\n          \"description\": \"Loss during training phase\"\n        },\n        \"val_loss\": {\n          \"type\": \"number\",\n          \"description\": \"Loss during validation phase\"\n        },\n        \"taskA_acc\": {\n          \"type\": \"number\",\n          \"description\": \"Accuracy for Task A\"\n        },\n        \"taskB_acc\": {\n          \"type\": \"number\",\n          \"description\": \"Accuracy for Task B\"\n        },\n        \"grad_norm\": {\n          \"type\": \"number\",\n          \"description\": \"Gradient norm value\"\n        },\n        \"PR_bc\": {\n          \"type\": \"number\",\n          \"description\": \"Precision-Recall break-even point\"\n        },\n        \"EGP\": {\n          \"type\": \"number\",\n          \"description\": \"Estimated Generalization Performance\"\n        },\n        \"lambda\": {\n          \"type\": \"number\",\n          \"description\": \"Regularization parameter lambda\"\n        }\n      },\n      \"required\": [\n        \"train_loss\", \"val_loss\", \"taskA_acc\", \"taskB_acc\", \"grad_norm\", \"PR_bc\", \"EGP\", \"lambda\"\n      ]\n    },\n    \"validation_constraints\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"run_id\": {\n          \"type\": \"string\",\n          \"description\": \"Unique identifier for the run\"\n        },\n        \"non_null_fields\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          },\n          \"description\": \"Fields that must not be null\"\n        }\n      },\n      \"required\": [\n        \"run_id\"\n      ]\n    },\n    \"failure_definitions\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"accuracy_drop_threshold\": {\n          \"type\": \"number\",\n          \"const\": 0.15,\n          \"description\": \"Threshold for acceptable accuracy drop\"\n        },\n        \"lookahead_k\": {\n          \"type\": \"integer\",\n          \"const\": 100,\n          \"description\": \"Lookahead parameter K\"\n        }\n      },\n      \"required\": [\n        \"accuracy_drop_threshold\", \"lookahead_k\"\n      ]\n    },\n    \"analysis_decision_thresholds\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"delta_AUC\": {\n          \"type\": \"number\",\n          \"minimum\": 0.03,\n          \"description\": \"Threshold for delta AUC\"\n        },\n        \"non_overlapping_CI\": {\n          \"type\": \"boolean\",\n          \"description\": \"Indicates if the confidence intervals overlap\"\n        }\n      },\n      \"required\": [\n        \"delta_AUC\", \"non_overlapping_CI\"\n      ]\n    },\n    \"analysis_lock\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"analysis_protocol_locked\": {\n          \"type\": \"boolean\",\n          \"const\": true,\n          \"description\": \"Indicates if the analysis protocol is locked\"\n        },\n        \"analysis_protocol_hash\": {\n          \"type\": \"string\",\n          \"description\": \"SHA256 hash for the analysis protocol\"\n        }\n      },\n      \"required\": [\n        \"analysis_protocol_locked\", \"analysis_protocol_hash\"\n      ]\n    }\n  },\n  \"required\": [\n    \"run_level_metadata\", \"time_series_metrics\", \"validation_constraints\", \"failure_definitions\", \"analysis_decision_thresholds\", \"analysis_lock\"\n  ]\n}