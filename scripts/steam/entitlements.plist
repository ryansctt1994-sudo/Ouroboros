<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    AIOS: Ouroboros — macOS hardened-runtime entitlements.
    Required for notarisation with py2app bundles.
-->
<plist version="1.0">
<dict>
    <!-- Allow JIT compilation (used by some Python extensions) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (py2app bootstrap) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Disable library validation so bundled .so files load correctly -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network access for Steam overlay and multiplayer -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
</dict>
</plist>
