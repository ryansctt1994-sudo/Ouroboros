# Example Environment Variables
# ==============================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control!

# Model Configuration
EDEN_MODEL_PATH=/models
EDEN_CACHE_SIZE=100

# Logging
EDEN_LOG_LEVEL=INFO

# API Keys (use Kubernetes secrets in production)
EDEN_API_KEY=your-api-key-here

# Telemetry
TELEMETRY_ENDPOINT=telemetry.example.com:50051
TELEMETRY_ENABLED=true

# gRPC Configuration
GRPC_PORT=50051
GRPC_MAX_WORKERS=10

# HTTP Server
HTTP_PORT=8080
METRICS_PORT=9090

# Performance Tuning
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT_SECONDS=30
